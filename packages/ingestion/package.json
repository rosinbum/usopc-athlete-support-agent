{
  "name": "@usopc/ingestion",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ingest": "dotenv -e ../../.env.local -- tsx src/scripts/ingest.ts",
    "seed": "dotenv -e ../../.env.local -- tsx src/scripts/seed.ts",
    "seed:pg": "dotenv -e ../../.env.local -- tsx src/scripts/seed-db.ts",
    "sources": "dotenv -e ../../.env.local -- tsx src/scripts/sources-cli.ts",
    "discovery:run": "dotenv -e ../../.env.local -- tsx src/scripts/discoveryCli.ts",
    "start": "dotenv -e ../../.env.local -- tsx src/httpServer.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "resend": "^6.12.3",
    "@langchain/anthropic": "^1.3.28",
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.44",
    "@langchain/openai": "^1.4.5",
    "@langchain/textsplitters": "^1.0.1",
    "@tavily/core": "^0.7.3",
    "@usopc/core": "workspace:*",
    "@usopc/shared": "workspace:*",
    "express": "^5.2.1",
    "cheerio": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
