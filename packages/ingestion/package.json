{
  "name": "@usopc/ingestion",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "ingest": "dotenv -e ../../.env.local -- tsx src/scripts/ingest.ts",
    "seed": "dotenv -e ../../.env.local -- tsx src/scripts/seed.ts",
    "seed:pg": "dotenv -e ../../.env.local -- tsx src/scripts/seed-db.ts",
    "sources": "dotenv -e ../../.env.local -- tsx src/scripts/sources-cli.ts",
    "discovery:run": "dotenv -e ../../.env.local -- tsx src/scripts/discoveryCli.ts",
    "start": "dotenv -e ../../.env.local -- tsx src/httpServer.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "resend": "^6.9.3",
    "@langchain/anthropic": "^1.3.22",
    "@langchain/community": "^1.1.22",
    "@langchain/core": "^1.1.31",
    "@langchain/openai": "^1.2.12",
    "@langchain/textsplitters": "^1.0.1",
    "@tavily/core": "^0.7.2",
    "@usopc/core": "workspace:*",
    "@usopc/shared": "workspace:*",
    "express": "^4.21.0",
    "cheerio": "^1.0.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^5.4.296",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.18.0",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
