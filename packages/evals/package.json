{
  "name": "@usopc/evals",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "eval": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts",
    "eval:classifier": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/classifierAccuracy.eval.ts",
    "eval:escalation": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/escalation.eval.ts",
    "eval:groundedness": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/groundedness.eval.ts",
    "eval:correctness": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/correctness.eval.ts",
    "eval:trajectory": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/trajectory.eval.ts",
    "eval:citations": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/citations.eval.ts",
    "eval:disclaimers": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/disclaimers.eval.ts",
    "eval:semantic": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/semanticSimilarity.eval.ts",
    "eval:quality": "dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/qualityReview.eval.ts",
    "eval:quality:full": "QUALITY_REVIEW_SCOPE=full dotenv -e ../../.env.local -- vitest run --config ls.vitest.config.ts src/evaluators/qualityReview.eval.ts",
    "seed-langsmith": "dotenv -e ../../.env.local -- tsx src/scripts/seed-datasets.ts",
    "seed-langsmith:force": "dotenv -e ../../.env.local -- tsx src/scripts/seed-datasets.ts --force",
    "quality:seed": "dotenv -e ../../.env.local -- tsx src/scripts/seed-quality-review.ts",
    "quality:run": "dotenv -e ../../.env.local -- tsx src/scripts/run-quality-review.ts",
    "quality:triage": "tsx src/scripts/triage.ts",
    "benchmark:embeddings": "dotenv -e ../../.env.local -- tsx src/scripts/benchmark-embeddings.ts",
    "corpus:generate": "tsx src/scripts/generate-test-corpus.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@langchain/core": "^1.1.31",
    "@langchain/openai": "^1.2.12",
    "@usopc/core": "workspace:*",
    "@usopc/shared": "workspace:*",
    "agentevals": "^0.0.7",
    "langsmith": "^0.5.7",
    "openevals": "^0.1.4"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
