# Database (local dev via docker-compose)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/usopc_athlete_support

# AI Model Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# Embeddings (optional — defaults to OpenAI)
VOYAGE_API_KEY=

# Web search (source discovery)
TAVILY_API_KEY=

# LangSmith tracing (optional)
LANGSMITH_API_KEY=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=usopc-athlete-support

# Auth
AUTH_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email
RESEND_API_KEY=

# Slack bot
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Admin
ADMIN_EMAILS=

# Resource bindings (local dev — placeholder values are fine for non-queue/storage work)
INGESTION_QUEUE_URL=placeholder
INGESTION_DLQ_URL=placeholder
DISCOVERY_FEED_QUEUE_URL=placeholder
DISCOVERY_FEED_DLQ_URL=placeholder
DOCUMENTS_BUCKET_NAME=placeholder

# Queue/Storage provider (defaults to GCP)
STORAGE_PROVIDER=gcs
QUEUE_PROVIDER=pubsub

# Auth is off by default. Set REQUIRE_AUTH=true to enforce (used in production).
# REQUIRE_AUTH=true

# App
NODE_ENV=development
LOG_LEVEL=debug
