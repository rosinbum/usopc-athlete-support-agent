{
  "name": "usopc-athlete-support-agent",
  "private": true,
  "version": "0.0.1",
  "description": "USOPC Athlete Support Agent - AI-powered governance and compliance assistant for U.S. Olympic and Paralympic athletes",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @usopc/web dev",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "pull-secrets": "scripts/pull-secrets.sh",
    "db:migrate": "dotenv -e .env.local -- npx tsx scripts/run-migrations.ts",
    "ingest": "pnpm --filter @usopc/ingestion ingest",
    "seed": "pnpm --filter @usopc/ingestion seed",
    "seed:pg": "pnpm --filter @usopc/ingestion seed:pg",
    "sources": "pnpm --filter @usopc/ingestion sources",
    "eval": "pnpm --filter @usopc/evals eval",
    "seed-langsmith": "pnpm --filter @usopc/evals seed-langsmith"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^2.1.9",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.4.2",
    "dotenv-cli": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "zod-to-json-schema": "3.24.1",
      "@langchain/openai": "^1.2.8",
      "hono": ">=4.12.4",
      "@modelcontextprotocol/sdk": ">=1.25.2",
      "h3": ">=1.15.5",
      "axios": ">=1.13.5",
      "rollup": ">=4.59.0",
      "undici": ">=7.24.0",
      "fast-xml-parser": ">=5.5.6",
      "path-to-regexp": ">=8.4.0",
      "handlebars": ">=4.7.9"
    },
    "patchedDependencies": {
      "@langchain/community": "patches/@langchain__community.patch"
    }
  }
}
